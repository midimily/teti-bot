{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Teti",
  "version": "0.1.0",
  "identifier": "im.midimily.teti.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "resources/lifecycle-sidecar/main.mjs": "lifecycle-sidecar/main.mjs",
      "resources/runtime/node": "runtime/node",
      "resources/runtime/deltachat-rpc-server": "runtime/deltachat-rpc-server"
    },
    "category": "Productivity",
    "copyright": "Copyright © 2026 Teti",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "15.0"
    }
  }
}
